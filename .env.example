# ============ 大模型（OpenAI 兼容） ============
MODEL_API_KEY=sk-your-api-key
MODEL_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4o-mini

# ============ MySQL ============
MYSQL_ROOT_PASSWORD=root
MYSQL_HOST=localhost
MYSQL_USER=aiinfra
MYSQL_PASSWORD=aiinfra
MYSQL_DATABASE=aiinfra

# ============ Redis ============
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_EXPIRE=86400

# ============ Milvus ============
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_DATABASE_NAME=default
MILVUS_COLLECTION_NAME=aiinfra_kb

# ============ 检索参数 ============
PARENT_CHUNK_SIZE=1200
CHILD_CHUNK_SIZE=300
CHUNK_OVERLAP=50
RETRIEVAL_K=5
CANDIDATE_M=2

# ============ Embedding ============
EMBEDDING_BACKEND=auto
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# ============ 本地 BGE 模型（Phase 3） ============
# 下载：pip install huggingface_hub && python scripts/download_bge_models.py
BGE_M3_PATH=models/bge-m3
BGE_RERANKER_PATH=models/bge-reranker-base
RERANK_BACKEND=auto
BGE_DEVICE=cpu
BGE_BATCH_SIZE=12
BGE_RERANK_BATCH_SIZE=32
BGE_USE_FP16=false
BGE_EMBEDDING_DIMENSION=1024

# ============ 其他本地模型路径 ============
BERT_BASE_PATH=
DOCUMENT_SEGMENTATION_PATH=
ORIGIN_MODEL_PATH=

# ============ MinIO ============
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=aiinfra
MINIO_SECURE=false

# ============ 网关 ============
APP_NAME=AI-Infra Gateway
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8080
ADMIN_TOKEN=change-me-admin-token
DEFAULT_RATE_LIMIT_RPM=60
AVAILABLE_MODELS=gpt-4o-mini,gpt-4o

# ============ RAG 服务 ============
RAG_APP_NAME=AI-Infra RAG
RAG_HOST=0.0.0.0
RAG_PORT=8081

# ============ 控制台 ============
CONSOLE_PORT=3000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ============ 监控（K8s Grafana） ============
GRAFANA_ADMIN_PASSWORD=admin

# ============ 应用 ============
VALID_SOURCES=["ai","java","test","ops","bigdata"]
CUSTOMER_SERVICE_PHONE=
