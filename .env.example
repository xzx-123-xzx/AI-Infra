# ============ 大模型（OpenAI 兼容） ============
MODEL_API_KEY=sk-your-api-key
MODEL_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4o-mini

# ============ MySQL ============
MYSQL_ROOT_PASSWORD=root
MYSQL_HOST=localhost
MYSQL_USER=aiinfra
MYSQL_PASSWORD=aiinfra
MYSQL_DATABASE=aiinfra

# ============ Redis ============
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_EXPIRE=86400

# ============ Milvus ============
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_DATABASE_NAME=default
MILVUS_COLLECTION_NAME=aiinfra_kb

# ============ 检索参数 ============
PARENT_CHUNK_SIZE=1200
CHILD_CHUNK_SIZE=300
CHUNK_OVERLAP=50
RETRIEVAL_K=5
CANDIDATE_M=2

# ============ Embedding ============
EMBEDDING_BACKEND=auto
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# ============ 本地 BGE 模型（Phase 3） ============
# 下载：pip install huggingface_hub && python scripts/download_bge_models.py
BGE_M3_PATH=models/bge-m3
BGE_RERANKER_PATH=models/bge-reranker-base
RERANK_BACKEND=auto
BGE_DEVICE=cpu
BGE_BATCH_SIZE=12
BGE_RERANK_BATCH_SIZE=32
BGE_USE_FP16=false
BGE_EMBEDDING_DIMENSION=1024

# ============ 其他本地模型路径 ============
BERT_BASE_PATH=
DOCUMENT_SEGMENTATION_PATH=
ORIGIN_MODEL_PATH=

# ============ MinIO ============
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=aiinfra
MINIO_SECURE=false

# ============ 智能路由（P0） ============
ROUTING_ENABLED=true
ROUTING_TOKEN_THRESHOLD=2000
ROUTING_SIMPLE_MODEL=gpt-4o-mini
ROUTING_COMPLEX_MODEL=gpt-4o
FALLBACK_MODEL=gpt-4o-mini
LOCAL_MODELS=qwen2.5-7b-instruct

# ============ 自托管推理（P0） ============
INFERENCE_PORT=8082
INFERENCE_BASE_URL=http://localhost:8082/v1
INFERENCE_API_KEY=local
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=empty

# ============ Agent（P0） ============
AGENT_PORT=8083
AGENT_MAX_STEPS=6
RAG_INTERNAL_URL=http://localhost:8081

# ============ 网关 ============
APP_NAME=AI-Infra Gateway
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8080
ADMIN_TOKEN=change-me-admin-token
DEFAULT_RATE_LIMIT_RPM=60
AVAILABLE_MODELS=gpt-4o-mini,gpt-4o,auto,qwen2.5-7b-instruct

# ============ RAG 服务 ============
RAG_APP_NAME=AI-Infra RAG
RAG_HOST=0.0.0.0
RAG_PORT=8081

# ============ 控制台 ============
CONSOLE_PORT=3000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ============ 监控（K8s Grafana） ============
GRAFANA_ADMIN_PASSWORD=admin

# ============ 混合检索（P1） ============
HYBRID_SEARCH_ENABLED=false
ES_HOST=localhost
ES_PORT=9200
ES_INDEX_PREFIX=aiinfra_chunks
RRF_K=60

# ============ Langfuse Trace（P1，可选） ============
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ============ 异步入库 / 多模态（P2） ============
INGESTION_ASYNC=true
INGESTION_WORKER_ENABLED=true
SYNC_WORKER_INTERVAL=300
OCR_BACKEND=off
ASR_BACKEND=api
OCR_VISION_MODEL=gpt-4o-mini
ASR_MODEL=whisper-1

# ============ MLOps（P3） ============
MLOPS_PORT=8084
MLOPS_WORKER_ENABLED=true
LORA_TRAIN_CMD=

# ============ Prompt 默认（P1） ============
DEFAULT_RAG_SYSTEM_PROMPT=你是企业知识库问答助手。请仅根据提供的上下文回答问题。如果上下文不足以回答，请明确说明不知道，不要编造。

# ============ 应用 ============
VALID_SOURCES=["ai","java","test","ops","bigdata"]
CUSTOMER_SERVICE_PHONE=
